# Copie para .env e preencha. NUNCA versione o .env real.
SECRET_KEY=troque-por-uma-chave-aleatoria-longa
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Supabase: use o Shared Pooler (Session mode, porta 5432). NAO use a conexao direta (IPv6).
# Pegue em: Supabase > Connect > Session pooler
# DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:5432/postgres?sslmode=require
# (Sem DATABASE_URL, o projeto usa SQLite local automaticamente.)
DATABASE_URL=
